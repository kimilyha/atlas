						local MouseY = math.clamp(Mouse.Y, MinY, MaxY)

						Colorpicker.Transparency = 1 - ((MouseY - MinY) / (MaxY - MinY))
						Colorpicker:Update()

						RenderStepped:Wait()
					end
				end
			end)
		end

		return Colorpicker
	end

	function Element:New(Config)
		local Colorpicker = {
