	local function Color3ToHSB(color)
		local r, g, b = color.R, color.G, color.B
		local max = math.max(r, g, b)
		local min = math.min(r, g, b)
		local delta = max - min

		local h = 0
		if delta ~= 0 then
			if max == r then
				h = (g - b) / delta % 6
			elseif max == g then
				h = (b - r) / delta + 2
			else
				h = (r - g) / delta + 4
			end
			h = h * 60
		else
			h = 0
		end

		local s = (max == 0) and 0 or (delta / max)
		local v = max

		return {
			h = math.floor(h + 0.5),
			s = s,
			b = v,
		}
	end

	local function GetPerceivedBrightness(color)
		local r = color.R
		local g = color.G
		local b = color.B
