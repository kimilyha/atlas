		--!optimize 2
		local redeemKey = function(key)
			local nonce = generateNonce()
			local endpoint = host .. "/public/redeem/" .. fToString(service)

			local body = {
				identifier = lDigest(fGetHwid()),
				key = key,
			}

			if useNonce then
				body.nonce = nonce
			end

			local response = fRequest({
				Url = endpoint,
				Method = "POST",
				Body = lEncode(body),
				Headers = {
					["Content-Type"] = "application/json",
				},
