local function requirePathToObjectPath(path, source)
	local fullPath = path

	local function consume(characters)
		path = string.sub(path, characters + 1)
	end

	local function extract(characters)
		return string.sub(path, 1, characters)
	end

	local function match(key)
		local length = string.len(key)

		if extract(length) == key then
			consume(length)
			return true
		end

		return false
	end

	if match("./") then
		source = source.Parent
	elseif match("../") then
		source = source.Parent.Parent
	elseif match("@game/") then
		source = game
	else
		match("@self/")
	end

	while path ~= "" do
		if match("./") then
			continue
		end

		if match("../") and source ~= game then
			source = source.Parent
			continue
		end

		local nextSlash = string.find(path, "/") or 0
		local child = extract(nextSlash - 1)
		consume(nextSlash - 2)
		consume(2)

		source = source[child]
		continue
	end

	return source
end

local modules, cache = {}, {}

local realRequire = require
local function spoofedRequire(module, source)
	if typeof(module) == "string" then
		module = requirePathToObjectPath(module, source)
	end

	local real, cached = modules[module], cache[module]

	if cached then
		return cached
	end

	if not real then
		return realRequire(module)
	end

	cache[module] = real()

	return cache[module]
end

