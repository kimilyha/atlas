								--         ColorSequenceKeypoint.new(0.0, Color3.fromRGB(255, 255, 255)),
								--         ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 255, 255)),
								--         ColorSequenceKeypoint.new(1.0, Color3.fromRGB(255, 255, 255)),
								--     }),
								--     Transparency = NumberSequence.new({
