								--         NumberSequenceKeypoint.new(0.5, 1),
								--         NumberSequenceKeypoint.new(1.0, 0.1),
								--     })
								-- }),
							}),
							New("Frame", {
								Size = UDim2.new(1, 0, 1, 0),
