					local MouseY = math.clamp(Mouse.Y, MinY, MaxY)

					Colorpicker.Hue = ((MouseY - MinY) / (MaxY - MinY))
					Colorpicker:Update()

					RenderStepped:Wait()
				end
			end
		end)

		if Colorpicker.Transparency then
			Creator.AddSignal(TransparencySlider.InputBegan, function(Input)
